TELEGRAM_TOKEN=your_bot_token_here
AUTHORIZED_USER_IDS=123456789,987654321   # comma-separated Telegram user IDs; leave empty to allow all
GUEST_NAME=zoomy.ircham.dev
RECORDINGS_DIR=/recordings
DEBUG=false   # set true to save debug screenshots to /recordings
WHISPER_MODEL=medium   # tiny | base | small | medium | large-v3
WHISPER_LANGUAGE=id    # BCP-47 language code, or leave empty for auto-detect
WHISPER_THREADS=       # CPU threads for Whisper inference; defaults to all available cores
WHISPER_INITIAL_PROMPT=   # primes context window with domain vocabulary; leave empty for default
WHISPER_HOTWORDS=         # comma-separated words to boost during transcription; leave empty for default

GEMINI_API_KEY=        # Gemini API key for transcript summarization; leave empty to disable the Summarize button
SUMMARY_MODEL=gemini-3.5-flash               # model used when web search is OFF
SUMMARY_WEB_SEARCH_MODEL=gemini-2.5-flash    # model used when web search is ON
SUMMARY_PREPROCESS_MODEL=gemini-3.1-flash-lite  # cheap model for unknown-term extraction
SUMMARY_WEB_SEARCH=true                      # set false to disable Google Search grounding

AUDIO_WAIT_TIMEOUT=1     # any non-zero value enables audio-wait on join (waits indefinitely until audio detected); 0 = disabled (start immediately)
AUDIO_RMS_THRESHOLD=100  # minimum RMS level (0–32767) to consider "audio present"

SILENT_WARN_SECS=60      # seconds of continuous silence mid-recording before Telegram warning; 0 = disabled
SILENT_SNOOZE_SECS=300   # how long (seconds) a snooze suppresses further silence warnings